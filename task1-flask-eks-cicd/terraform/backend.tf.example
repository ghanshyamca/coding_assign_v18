# Remote state backend (EXAMPLE ONLY)
#
# Copy this file to backend.tf and fill in your own bucket / table names to
# store Terraform state remotely in S3 with DynamoDB state locking.
#
# Prerequisites (create these once, out-of-band, before `terraform init`):
#   aws s3api create-bucket --bucket my-flask-eks-tfstate --region us-east-1
#   aws s3api put-bucket-versioning --bucket my-flask-eks-tfstate \
#       --versioning-configuration Status=Enabled
#   aws dynamodb create-table --table-name flask-eks-tf-lock \
#       --attribute-definitions AttributeName=LockID,AttributeType=S \
#       --key-schema AttributeName=LockID,KeyType=HASH \
#       --billing-mode PAY_PER_REQUEST --region us-east-1
