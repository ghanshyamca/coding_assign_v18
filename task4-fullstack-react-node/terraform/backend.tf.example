# Remote state backend (recommended for team / CI use).
#
# 1. Create the S3 bucket and DynamoDB lock table ONCE (out of band), e.g.:
#
#    aws s3api create-bucket --bucket my-tf-state-fullstack --region us-east-1
#    aws s3api put-bucket-versioning --bucket my-tf-state-fullstack \
#      --versioning-configuration Status=Enabled
#    aws dynamodb create-table --table-name terraform-locks \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST --region us-east-1
#
# 2. Rename this file to backend.tf and run `terraform init -migrate-state`.

# terraform {
#   backend "s3" {
#     bucket         = "my-tf-state-fullstack"
#     key            = "task4-fullstack-react-node/terraform.tfstate"
#     region         = "us-east-1"
#     dynamodb_table = "terraform-locks"
#     encrypt        = true
#   }
# }
