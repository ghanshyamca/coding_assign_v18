// Shared declarative pipeline that builds, pushes, and deploys BOTH the
// React frontend and the Node.js backend to EKS.
//
// Required Jenkins plugins:
//   - Docker Pipeline
//   - Pipeline: AWS Steps (or use the AWS CLI on the agent)
//   - Kubernetes CLI (or kubectl available on the agent)
// Required credentials (Manage Jenkins > Credentials):
//   - aws-credentials : kind "AWS Credentials" (same entry as tasks 1-3;
//     or use an IAM instance role on the agent and drop withCredentials).
// Agent prerequisites: docker, aws cli v2, kubectl, node 20.

pipeline {
  agent any

  environment {
    AWS_REGION    = 'us-east-1'
    AWS_ACCOUNT   = '848504403205'
    CLUSTER_NAME  = 'fullstack-dev-eks'
    K8S_NAMESPACE = 'fullstack'

    FRONTEND_REPO = 'fullstack-frontend'
    BACKEND_REPO  = 'fullstack-backend'

    ECR_REGISTRY  = "${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    IMAGE_TAG     = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : env.BUILD_NUMBER}"
  }

  options {
    timestamps()
    disableConcurrentBuilds()
    timeout(time: 30, unit: 'MINUTES')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    // Build + unit test both services concurrently.
    stage('Build & Test') {
      parallel {
        stage('Backend') {
          steps {
            dir('task4-fullstack-react-node/backend') {
              sh 'npm ci'
              sh 'npm test'
            }
          }
        }
        stage('Frontend') {
          steps {
            dir('task4-fullstack-react-node/frontend') {
              sh 'npm ci'
              sh 'npm test'
              sh 'npm run build'
            }
          }
        }
      }
    }

    stage('ECR Login') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh '''
            aws ecr get-login-password --region "$AWS_REGION" \
              | docker login --username AWS --password-stdin "$ECR_REGISTRY"
          '''
        }
      }
    }

    // Build and push both images concurrently, tagged with the git sha.
    stage('Docker Build & Push') {
      parallel {
        stage('Backend Image') {
          steps {
            dir('task4-fullstack-react-node/backend') {
              sh '''
                docker build -t "$ECR_REGISTRY/$BACKEND_REPO:$IMAGE_TAG" \
                             -t "$ECR_REGISTRY/$BACKEND_REPO:latest" .
                docker push "$ECR_REGISTRY/$BACKEND_REPO:$IMAGE_TAG"
                docker push "$ECR_REGISTRY/$BACKEND_REPO:latest"
              '''
            }
          }
        }
        stage('Frontend Image') {
          steps {
            dir('task4-fullstack-react-node/frontend') {
              sh '''
                docker build -t "$ECR_REGISTRY/$FRONTEND_REPO:$IMAGE_TAG" \
                             -t "$ECR_REGISTRY/$FRONTEND_REPO:latest" .
                docker push "$ECR_REGISTRY/$FRONTEND_REPO:$IMAGE_TAG"
                docker push "$ECR_REGISTRY/$FRONTEND_REPO:latest"
              '''
            }
          }
        }
      }
    }

    stage('Configure kubectl') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh '''
            aws eks update-kubeconfig --region "$AWS_REGION" --name "$CLUSTER_NAME"
          '''
        }
      }
    }

    stage('Deploy to EKS') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh '''
            # Ensure namespace and base manifests exist (idempotent).
            kubectl apply -f task4-fullstack-react-node/k8s/namespace.yaml
            kubectl apply -f task4-fullstack-react-node/k8s/backend-deployment.yaml
            kubectl apply -f task4-fullstack-react-node/k8s/backend-service.yaml
            kubectl apply -f task4-fullstack-react-node/k8s/frontend-deployment.yaml
            kubectl apply -f task4-fullstack-react-node/k8s/frontend-service.yaml
            kubectl apply -f task4-fullstack-react-node/k8s/ingress.yaml

            # Roll out the freshly built, sha-tagged images for both services.
            kubectl -n "$K8S_NAMESPACE" set image deployment/fullstack-backend \
              backend="$ECR_REGISTRY/$BACKEND_REPO:$IMAGE_TAG"
            kubectl -n "$K8S_NAMESPACE" set image deployment/fullstack-frontend \
              frontend="$ECR_REGISTRY/$FRONTEND_REPO:$IMAGE_TAG"
          '''
        }
      }
    }

    stage('Verify Rollouts') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh '''
            kubectl -n "$K8S_NAMESPACE" rollout status deployment/fullstack-backend --timeout=180s
            kubectl -n "$K8S_NAMESPACE" rollout status deployment/fullstack-frontend --timeout=180s
          '''
        }
      }
    }
  }

  post {
    success {
      echo "Deployed frontend and backend at tag ${IMAGE_TAG} to ${CLUSTER_NAME}."
    }
    failure {
      echo 'Pipeline failed. Check the failing stage logs above.'
    }
    always {
      // Remove local images to keep the agent disk clean.
      sh 'docker image prune -f || true'
      cleanWs()
    }
  }
}
