###############################################################################
# backend.tf.example
#
# Remote state backend using S3 for state storage and DynamoDB for state
# locking. Copy this file to backend.tf and fill in your bucket / table, then
# run `terraform init -migrate-state`.
#
# Pre-reqs (create once, out-of-band, before terraform init):
#   aws s3api create-bucket --bucket my-tf-state-bluegreen --region us-east-1
#   aws s3api put-bucket-versioning --bucket my-tf-state-bluegreen \
#       --versioning-configuration Status=Enabled
#   aws dynamodb create-table --table-name tf-locks-bluegreen \
#       --attribute-definitions AttributeName=LockID,AttributeType=S \
#       --key-schema AttributeName=LockID,KeyType=HASH \
#       --billing-mode PAY_PER_REQUEST
###############################################################################

# terraform {
#   backend "s3" {
#     bucket         = "my-tf-state-bluegreen"
#     key            = "task2-bluegreen-node-helm/terraform.tfstate"
#     region         = "us-east-1"
#     dynamodb_table = "tf-locks-bluegreen"
#     encrypt        = true
#   }
# }
