// Declarative Jenkins pipeline for building, pushing and deploying ha-app to EKS.
//
// Credentials (configure in Jenkins > Manage Credentials):
//   * aws-credentials  - kind "AWS Credentials" (same entry as tasks 1-4)
//                        with rights to ECR + EKS. Alternatively run Jenkins
//                        on an EC2 instance role and drop the withCredentials.
// Required agent tooling: docker, aws cli v2, kubectl.

pipeline {
  agent any

  environment {
    AWS_REGION   = 'us-east-1'
    APP_NAME     = 'ha-app'
    ECR_REPO     = 'ha-app'
    CLUSTER_NAME = 'ha-app-eks'
    K8S_NS       = 'ha-app'
    // Derived at runtime.
    IMAGE_TAG    = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'latest'}"
  }

  options {
    timestamps()
    disableConcurrentBuilds()
    timeout(time: 30, unit: 'MINUTES')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        script {
          env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
          env.IMAGE_TAG = env.GIT_SHA
        }
      }
    }

    stage('Resolve ECR registry') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          script {
            env.ACCOUNT_ID = sh(
              script: "aws sts get-caller-identity --query Account --output text",
              returnStdout: true
            ).trim()
            env.ECR_URL = "${env.ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com/${env.ECR_REPO}"
            echo "Image will be: ${env.ECR_URL}:${env.IMAGE_TAG}"
          }
        }
      }
    }

    stage('Build') {
      steps {
        dir('task5-ha-autoscaling/app') {
          sh "docker build -t ${env.APP_NAME}:${env.IMAGE_TAG} ."
        }
      }
    }

    stage('Test') {
      steps {
        dir('task5-ha-autoscaling/app') {
          sh 'npm install --no-audit --no-fund'
          sh 'npm test'
        }
      }
    }

    stage('ECR login + push') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh """
            aws ecr get-login-password --region ${env.AWS_REGION} \
              | docker login --username AWS --password-stdin ${env.ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com
            docker tag ${env.APP_NAME}:${env.IMAGE_TAG} ${env.ECR_URL}:${env.IMAGE_TAG}
            docker tag ${env.APP_NAME}:${env.IMAGE_TAG} ${env.ECR_URL}:latest
            docker push ${env.ECR_URL}:${env.IMAGE_TAG}
            docker push ${env.ECR_URL}:latest
          """
        }
      }
    }

    stage('Update kubeconfig') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh "aws eks update-kubeconfig --region ${env.AWS_REGION} --name ${env.CLUSTER_NAME}"
        }
      }
    }

    stage('Deploy') {
      steps {
        dir('task5-ha-autoscaling') {
          withCredentials([aws(credentialsId: 'aws-credentials')]) {
            sh """
              kubectl apply -f k8s/namespace.yaml

              # Inject the freshly pushed image into the deployment manifest.
              sed 's|<ECR_URL>:latest|${env.ECR_URL}:${env.IMAGE_TAG}|g' k8s/deployment.yaml \
                | kubectl apply -f -

              kubectl apply -f k8s/service.yaml
              kubectl apply -f k8s/hpa.yaml
              kubectl apply -f k8s/pdb.yaml
            """
          }
        }
      }
    }

    stage('Verify rollout') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh "kubectl -n ${env.K8S_NS} rollout status deployment/${env.APP_NAME} --timeout=180s"
        }
      }
    }

    stage('Show HPA') {
      steps {
        withCredentials([aws(credentialsId: 'aws-credentials')]) {
          sh "kubectl -n ${env.K8S_NS} get hpa ${env.APP_NAME}"
          sh "kubectl -n ${env.K8S_NS} get pods -o wide"
        }
      }
    }
  }

  post {
    success {
      echo "Deployed ${env.ECR_URL}:${env.IMAGE_TAG} to ${env.CLUSTER_NAME}."
    }
    failure {
      echo "Pipeline failed. Check the stage logs above."
    }
    always {
      sh 'docker image prune -f || true'
    }
  }
}
